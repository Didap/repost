# Default Instagram target seeded into the DB on first boot. After that you
# manage targets from the dashboard. Leave blank to start with no target.
IG_TARGET_USERNAME=target_account

# Polling interval in seconds (min 300 recommended to avoid rate limits)
POLL_INTERVAL_SECONDS=600

# Caption del nuovo post. Default: copia verbatim → sembra contenuto tuo.
# Placeholders: {caption}, {target}
CAPTION_TEMPLATE={caption}

# true = al primo avvio NON processa i post storici del target
SKIP_INITIAL=true

# Storage (auto in Docker = /app/data)
DATA_DIR=./data

# Optional: bootstrap della sessione IG via env. Lascia vuoto per incollarla
# dalla dashboard.
# IG_SESSIONID=

# ---- Web dashboard ----

# Required: bootstrap admin (creato sul DB al primo avvio se non ci sono utenti).
# Da qui in poi gli utenti si gestiscono dalla dashboard (Settings → Utenti).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=cambiami-subito-min-8-char

# Bind / port (default 0.0.0.0:8000)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Optional: forza un secret stabile per i cookie. Se omesso, ne viene
# generato uno persistente in $DATA_DIR/cookie.secret.
# COOKIE_SECRET=
