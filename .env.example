# Instagram target page to monitor (without @)
IG_TARGET_USERNAME=target_account

# Telegram bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Polling interval in seconds (min 300 recommended to avoid rate limits)
POLL_INTERVAL_SECONDS=600

# Caption del nuovo post. Default: copia verbatim → sembra contenuto tuo.
# Placeholders: {caption}, {target}
CAPTION_TEMPLATE={caption}

# true = al primo avvio NON ti chiede dei post storici del target
SKIP_INITIAL=true

# Storage (auto in Docker = /app/data)
DATA_DIR=./data

# OPZIONALE: bootstrap della sessione IG via env. Lascia vuoto per usare /auth da Telegram.
# IG_SESSIONID=
